---
import { Icon } from "astro-icon/components";
import { ICONS } from "../../data/icons";
---

<section id="eligibility-criteria" class="section">
  <div class="section-inner">
    <div class="max-w-3xl">
      <p class="eyebrow">Foundation</p>
      <h2 class="section-title mt-3">Eligibility criteria to apply.</h2>
      <p class="section-lead">
        To be eligible for admission to Gharbiya STEM High School, you must meet
        all of the following requirements.
      </p>
    </div>

    <div class="mt-10 space-y-6">
      <div class="surface p-8">
        <div class="mb-6 flex items-center gap-3">
          <div
            class="bg-primary/10 flex h-10 w-10 items-center justify-center rounded-full"
          >
            <Icon
              name={ICONS.eligibility}
              class="text-primary h-5 w-5"
              aria-hidden="true"
            />
          </div>
          <h3 class="text-foreground text-xl font-semibold">
            Basic Requirements
          </h3>
        </div>
        <ul class="text-foreground space-y-3 text-sm">
          <li class="flex gap-3">
            <Icon
              name={ICONS.checkCircle}
              class="text-primary mt-0.5 h-4 w-4 flex-shrink-0"
              aria-hidden="true"
            />
            <span><strong>Egyptian nationality</strong> required</span>
          </li>
          <li class="flex gap-3">
            <Icon
              name={ICONS.checkCircle}
              class="text-primary mt-0.5 h-4 w-4 flex-shrink-0"
              aria-hidden="true"
            />
            <span>Age: <strong>18 years old or younger</strong></span>
          </li>
          <li class="flex gap-3">
            <Icon
              name={ICONS.checkCircle}
              class="text-primary mt-0.5 h-4 w-4 flex-shrink-0"
              aria-hidden="true"
            />
            <span>Currently enrolled as a <strong>Grade 9 student</strong></span
            >
          </li>
        </ul>
      </div>

      <div class="space-y-4">
        <div class="flex items-center gap-3">
          <div
            class="bg-primary/10 flex h-10 w-10 items-center justify-center rounded-full"
          >
            <Icon
              name={ICONS.academics}
              class="text-primary h-5 w-5"
              aria-hidden="true"
            />
          </div>
          <h3 class="text-foreground text-xl font-semibold">
            Academic Excellence (Choose One)
          </h3>
        </div>

        <div class="grid gap-4 md:grid-cols-2">
          <div class="surface p-6">
            <div
              class="bg-primary/10 text-primary mb-4 inline-block rounded-full px-3 py-1 text-sm font-semibold"
            >
              Case 1
            </div>
            <h4 class="text-foreground mt-3 text-lg font-semibold">
              High Overall Score
            </h4>
            <p class="text-muted-foreground mt-2 text-sm">
              Total Grade 9 score of <strong>98% or higher</strong>
            </p>
            <p class="text-muted-foreground mt-1 text-xs">
              (274.5 out of 280 points)
            </p>
            <p class="text-foreground mt-3 text-sm">
              <Icon
                name={ICONS.checkCircle}
                class="text-primary mr-2 mb-1 inline h-4 w-4"
                aria-hidden="true"
              />
              No full marks required in any subject
            </p>
          </div>

          <div class="surface p-6">
            <div
              class="bg-primary/10 text-primary mb-4 inline-block rounded-full px-3 py-1 text-sm font-semibold"
            >
              Case 2
            </div>
            <h4 class="text-foreground mt-3 text-lg font-semibold">
              Strong Score with Excellence
            </h4>
            <p class="text-muted-foreground mt-2 text-sm">
              Total Grade 9 score of <strong>95% or higher</strong>
            </p>
            <p class="text-muted-foreground mt-1 text-xs">
              (266 out of 280 points)
            </p>
            <p class="text-foreground mt-3 text-sm">
              <Icon
                name={ICONS.checkCircle}
                class="text-primary mr-2 mb-1 inline h-4 w-4"
                aria-hidden="true"
              />
              PLUS full mark (100%) in Maths, Science, or English
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
