---
import { Icon } from "astro-icon/components";
import { ICONS } from "../../data/icons";
---

<section id="contact-admissions" class="section">
  <div class="section-inner">
    <div class="mx-auto max-w-2xl">
      <div>
        <div>
          <p class="eyebrow">Get in touch</p>
          <h2 class="section-title mt-3">Questions about admission?</h2>
          <p class="section-lead mt-4">
            Our admissions team and school counselors are here to help guide you
            through the process.
          </p>

          <div class="mt-8 space-y-6">
            <div class="flex gap-4">
              <Icon
                name={ICONS.mapMarker}
                class="text-primary h-6 w-6 flex-shrink-0"
                aria-hidden="true"
              />
              <div>
                <h3 class="text-foreground font-semibold">Address</h3>
                <p class="text-muted-foreground mt-1 text-sm">
                  Gharbiya STEM School, School Campus
                  <br />
                  El-Galaa, Tanta
                  <br />
                  El Gharbiya, Egypt
                </p>
              </div>
            </div>

            <div class="flex gap-4">
              <Icon
                name={ICONS.contact}
                class="text-primary h-6 w-6 flex-shrink-0"
                aria-hidden="true"
              />
              <div>
                <h3 class="text-foreground font-semibold">Phone</h3>
                <a
                  href="tel:+20403556263"
                  class="text-primary mt-1 text-sm transition hover:underline"
                >
                  (+2) 0403556263
                </a>
                <p class="text-muted-foreground text-xs">
                  Available during school hours
                </p>
              </div>
            </div>

            <div class="flex gap-4">
              <Icon
                name={ICONS.contact}
                class="text-primary h-6 w-6 flex-shrink-0"
                aria-hidden="true"
              />
              <div>
                <h3 class="text-foreground font-semibold">School Email</h3>
                <a
                  href="mailto:gharbiasch@stemgharbiya.moe.edu.eg"
                  class="text-primary mt-1 text-sm transition hover:underline"
                >
                  gharbiasch@stemgharbiya.moe.edu.eg
                </a>
              </div>
            </div>

            <div class="flex gap-4">
              <Icon
                name={ICONS.contact}
                class="text-primary h-6 w-6 flex-shrink-0"
                aria-hidden="true"
              />
              <div>
                <h3 class="text-foreground font-semibold">Counselor</h3>
                <a
                  href="mailto:ereny.awad@stemgharbiya.moe.edu.eg"
                  class="text-primary mt-1 text-sm transition hover:underline"
                >
                  ereny.awad@stemgharbiya.moe.edu.eg
                </a>
                <p class="text-muted-foreground mt-1 text-xs">
                  For personal guidance and mentorship
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
