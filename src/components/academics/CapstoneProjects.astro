---
interface CapstoneProject {
  title: string;
  description: string;
  outcomes: string[];
  year: string;
}

interface Props {
  projects: CapstoneProject[];
}

const { projects } = Astro.props;
---

<section class="section" id="capstone">
  <div class="section-inner">
    <div class="max-w-3xl">
      <p class="eyebrow">Student Research</p>
      <h2 class="section-title mt-3">Capstone Projects.</h2>
      <p class="section-lead">
        Every student completes an independent or collaborative capstone
        project, resulting in publishable research, patent filings, or
        real-world applications.
      </p>
    </div>

    <div class="mt-12 grid gap-6 lg:grid-cols-2">
      {
        projects.map((project) => (
          <div class="surface flex h-full flex-col p-8">
            <div class="mb-4 flex items-start justify-between gap-4">
              <div>
                <h3 class="text-foreground text-xl font-semibold">
                  {project.title}
                </h3>
                <p class="text-muted-foreground mt-1 text-xs tracking-[0.1em] uppercase">
                  Class of {project.year}
                </p>
              </div>
            </div>

            <p class="text-muted-foreground mb-4 flex-grow text-sm">
              {project.description}
            </p>

            <div>
              <p class="text-muted-foreground mb-3 text-xs tracking-[0.1em] uppercase">
                Outcomes
              </p>
              <ul class="space-y-2">
                {project.outcomes.map((outcome) => (
                  <li class="text-foreground flex items-center gap-2 text-sm">
                    <span class="bg-primary h-1.5 w-1.5 flex-shrink-0 rounded-full" />
                    {outcome}
                  </li>
                ))}
              </ul>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
