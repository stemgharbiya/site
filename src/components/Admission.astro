---
import { Icon } from "astro-icon/components";
import { ICONS, type IconKey } from "../data/icons";

const checklist: { icon: IconKey; text: string }[] = [
  { icon: "eligibility", text: "Eligibility criteria and required documents." },
  { icon: "timeline", text: "Joining timeline and key dates." },
  { icon: "exam", text: "Entrance exam format and preparation tips." },
];
---

<section class="section">
  <div class="section-inner">
    <div
      class="border-border from-background via-background to-secondary/60 relative overflow-hidden rounded-3xl border bg-gradient-to-br p-8 md:p-12"
    >
      <div
        class="bg-primary/10 absolute -top-16 right-0 h-48 w-48 rounded-full blur-3xl"
        aria-hidden="true"
      >
      </div>
      <div class="relative grid gap-8 lg:grid-cols-[1.1fr_0.9fr]">
        <div>
          <p class="eyebrow">Admissions</p>
          <h2 class="section-title mt-3">Learn how to join STEM Gharbiya.</h2>
          <p class="section-lead">
            Learn eligibility details, the joining timeline, and exam
            preparation guidance for STEM Gharbiya.
          </p>
          <div class="mt-6 flex flex-wrap gap-4">
            <a href="/about/admission" class="btn-primary">Learn how to join</a>
            <a href="/contact" class="btn-secondary">Have a question?</a>
          </div>
        </div>
        <div class="surface p-6">
          <h3 class="text-foreground text-base font-semibold">
            What to expect
          </h3>
          <ul class="text-muted-foreground mt-4 space-y-3 text-sm">
            {
              checklist.map((item) => (
                <li class="flex gap-3">
                  <Icon
                    name={ICONS[item.icon as IconKey]}
                    class="text-primary h-[18px] w-[18px]"
                    aria-hidden="true"
                  />
                  {item.text}
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>
