---
import Layout from "./Layout.astro";
import { siteConfig } from "../data/constants";
import { buildBreadcrumbListNode, cleanCanonicalUrl } from "../lib/schema";

interface Props {
  sectionTitle: string;
  sectionPath: string;
  description?: string;
  eyebrow?: string;
  headline?: string;
  lead?: string;
  linksInHead?: string[];
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
  breadcrumbItems?: { name: string; path: string }[];
  pageType?: string;
  noIndex?: boolean;
}

const {
  sectionTitle,
  sectionPath,
  description,
  eyebrow = "About",
  headline,
  lead,
  linksInHead = [],
  structuredData,
  breadcrumbItems = [],
  pageType,
  noIndex,
} = Astro.props;

const normalizedSectionPath = sectionPath.startsWith("/")
  ? sectionPath
  : `/${sectionPath}`;
const aboutPath = "/about";
const currentUrl = cleanCanonicalUrl(
  Astro.url?.href ?? siteConfig.url,
  siteConfig.url,
);
const normalizedHeadline = headline ?? sectionTitle;
const normalizedLead = lead ?? description;
const normalizeBreadcrumbPath = (path: string) =>
  path === "/" ? "/" : path.endsWith("/") ? path : `${path}/`;

const breadcrumbTrail = [
  { name: "Home", path: "/" },
  ...(normalizedSectionPath === aboutPath
    ? []
    : [{ name: "About", path: aboutPath }]),
  ...breadcrumbItems,
  ...(normalizedSectionPath === aboutPath
    ? [{ name: "About", path: aboutPath }]
    : [{ name: sectionTitle, path: normalizedSectionPath }]),
].map((item) => ({
  ...item,
  path: normalizeBreadcrumbPath(item.path),
}));

const dedupedBreadcrumbTrail = breadcrumbTrail.filter(
  (item, index, array) =>
    index ===
    array.findIndex(
      (entry) => entry.name === item.name && entry.path === item.path,
    ),
);

const breadcrumbSchema = buildBreadcrumbListNode({
  pageUrl: currentUrl,
  items: dedupedBreadcrumbTrail.map((item) => ({
    name: item.name,
    item: `${siteConfig.url}${item.path}`,
  })),
});

const additionalStructuredData = structuredData
  ? Array.isArray(structuredData)
    ? structuredData
    : [structuredData]
  : [];

const pageStructuredData = [breadcrumbSchema, ...additionalStructuredData];
---

<Layout
  title={`${sectionTitle} | About`}
  description={description}
  linksInHead={linksInHead}
  structuredData={pageStructuredData}
  pageType={pageType}
  noIndex={noIndex}
>
  <section
    class="from-primary/10 via-background to-background relative overflow-hidden bg-linear-to-b py-16 md:py-20"
    transition:name="about-hero"
  >
    <div
      class="bg-primary/10 absolute -top-24 right-0 h-72 w-72 rounded-full blur-3xl"
      aria-hidden="true"
    >
    </div>
    <div
      class="bg-secondary/80 absolute -bottom-24 left-0 h-72 w-72 rounded-full blur-3xl"
      aria-hidden="true"
    >
    </div>

    <div class="section-inner relative">
      <nav aria-label="Breadcrumb" class="text-muted-foreground text-sm">
        <ol class="flex flex-wrap items-center gap-2">
          {
            dedupedBreadcrumbTrail.map((item, index) => {
              const isLast = index === dedupedBreadcrumbTrail.length - 1;
              return (
                <Fragment>
                  <li>
                    {isLast ? (
                      <span class="text-foreground">{item.name}</span>
                    ) : (
                      <a
                        href={item.path}
                        class="hover:text-foreground transition"
                      >
                        {item.name}
                      </a>
                    )}
                  </li>
                  {!isLast && <li aria-hidden="true">/</li>}
                </Fragment>
              );
            })
          }
        </ol>
      </nav>

      <div class="mt-6 max-w-3xl">
        <p class="eyebrow">{eyebrow}</p>
        <h1 class="section-title mt-3">{normalizedHeadline}</h1>
        {
          normalizedLead && (
            <p class="section-lead max-w-2xl">{normalizedLead}</p>
          )
        }
      </div>
    </div>
  </section>

  <slot />
</Layout>
