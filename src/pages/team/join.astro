---
import { TURNSTILE_SITE_KEY } from "astro:env/client";
import FormLayout from "../../layouts/FormLayout.astro";
import { ALLOWED_INTERESTS } from "../../data/forms";
import { siteConfig } from "../../data/constants";
import { buildBreadcrumbListNode, cleanCanonicalUrl } from "../../lib/schema";

const linksInHead = [
  '<link rel="preconnect" href="https://challenges.cloudflare.com" />',
  '<script src="https://challenges.cloudflare.com/turnstile/v0/api.js" defer async></script>',
];

const currentUrl = cleanCanonicalUrl(
  Astro.url?.href ?? `${siteConfig.url}/team/join`,
  siteConfig.url,
);

const structuredData = [
  buildBreadcrumbListNode({
    pageUrl: currentUrl,
    items: [
      { name: "Home", item: siteConfig.url },
      { name: "Team", item: `${siteConfig.url}/team` },
      { name: "Join", item: currentUrl },
    ],
  }),
];
---

<FormLayout
  title="Join Development Team"
  description="Apply to join the STEM Gharbiya development team and contribute to real projects, open-source workflows, and student-focused products."
  pageType="WebPage"
  linksInHead={linksInHead}
  structuredData={structuredData}
  sidebarEyebrow="Dev team applications"
  sidebarTitle="Join STEM Gharbiya Dev Team"
  sidebarDescription="Apply to join our dev team to collaborate on open-source projects, learn industry workflows, and build real impact for students."
  formEyebrow="Apply now"
  formTitle="Quick application"
  formDescription="Complete the form below — submissions are reviewed within 2–3 business days."
>
  <Fragment slot="sidebarContent">
    <ul class="mt-6 space-y-3 text-sm">
      <li class="flex items-start gap-3">
        <svg
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          class="text-primary mt-1"
          aria-hidden
        >
          <path
            d="M5 12l4 4L19 6"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
        <span><strong>Mentorship</strong> from experienced contributors.</span>
      </li>
      <li class="flex items-start gap-3">
        <svg
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          class="text-primary mt-1"
          aria-hidden
        >
          <path
            d="M12 20l9-5-9-5-9 5 9 5z"
            stroke="currentColor"
            stroke-width="1"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
        <span><strong>Hands-on</strong> work on real projects.</span>
      </li>
      <li class="flex items-start gap-3">
        <svg
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          class="text-primary mt-1"
          aria-hidden
        >
          <path
            d="M12 2v20"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
          <path
            d="M2 12h20"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
        <span><strong>Community</strong> & networking with peers.</span>
      </li>
    </ul>

    <p class="text-muted-foreground mt-6 text-xs">
      Tip: Have your GitHub profile ready and use your school email.
    </p>
  </Fragment>

  <div id="alertsContainer" class="mt-4"></div>

  <div class="mt-3">
    <a
      href="/team"
      class="text-primary hover:text-primary/80 inline-flex items-center text-sm font-medium underline underline-offset-4 transition"
    >
      ← View current development team
    </a>
  </div>

  <form id="applicationForm" class="mt-6 grid gap-3">
    <div class="space-y-2">
      <label for="fullName" class="text-foreground text-sm font-medium">
        Full Name <span class="text-destructive">*</span>
      </label>
      <input
        type="text"
        id="fullName"
        name="fullName"
        required
        class="border-border bg-background text-foreground focus:border-ring focus:ring-ring/20 w-full rounded-xl border px-3 py-2 text-sm shadow-sm transition focus:ring-2 focus:outline-none"
      />
      <div class="error text-destructive hidden text-xs" id="nameError"></div>
    </div>

    <div class="space-y-2">
      <label for="schoolEmail" class="text-foreground text-sm font-medium">
        School Email <span class="text-destructive">*</span>
      </label>
      <input
        type="email"
        id="schoolEmail"
        name="schoolEmail"
        required
        class="border-border bg-background text-foreground focus:border-ring focus:ring-ring/20 w-full rounded-xl border px-3 py-2 text-sm shadow-sm transition focus:ring-2 focus:outline-none"
      />
      <span class="text-muted-foreground text-xs">
        Must end with @stemgharbiya.moe.edu.eg
      </span>
      <div class="error text-destructive hidden text-xs" id="emailError"></div>
    </div>

    <div class="space-y-2">
      <label for="githubUsername" class="text-foreground text-sm font-medium">
        GitHub Username <span class="text-destructive">*</span>
      </label>
      <input
        type="text"
        id="githubUsername"
        name="githubUsername"
        required
        class="border-border bg-background text-foreground focus:border-ring focus:ring-ring/20 w-full rounded-xl border px-3 py-2 text-sm shadow-sm transition focus:ring-2 focus:outline-none"
      />
      <div class="error text-destructive hidden text-xs" id="githubError"></div>
    </div>

    <div class="space-y-2">
      <label for="seniorYear" class="text-foreground text-sm font-medium">
        Senior Year <span class="text-destructive">*</span>
      </label>
      <input
        type="text"
        id="seniorYear"
        name="seniorYear"
        pattern="^[Ss](2[5-9]|30)$"
        title="Format: S25, S26, S27, S28, S29, or S30 only"
        placeholder="S25, S26, S27, etc."
        required
        class="border-border bg-background text-foreground focus:border-ring focus:ring-ring/20 w-full rounded-xl border px-3 py-2 text-sm shadow-sm transition focus:ring-2 focus:outline-none"
      />
      <span class="text-muted-foreground text-xs">
        Format: S followed by graduation year (S25-S30 only)
      </span>
      <div class="error text-destructive hidden text-xs" id="seniorYearError">
      </div>
    </div>

    <div class="space-y-3">
      <label class="text-foreground text-sm font-medium">
        Interests <span class="text-destructive">*</span>
      </label>
      <div class="grid gap-3 sm:grid-cols-2" id="interestsContainer">
        {
          ALLOWED_INTERESTS.map((interest) => (
            <div class="border-border bg-secondary/40 text-foreground flex items-start gap-3 rounded-xl border px-3 py-3 text-sm">
              <input
                type="checkbox"
                name="interests"
                value={interest}
                id={`interest-${interest}`}
                class="border-border text-primary focus:ring-primary/30 mt-1 h-4 w-4 rounded"
              />
              <label for={`interest-${interest}`} class="leading-5">
                {interest}
              </label>
            </div>
          ))
        }
      </div>
      <div class="error text-destructive hidden text-xs" id="interestsError">
      </div>
    </div>

    <div class="space-y-2">
      <label for="motivation" class="text-foreground text-sm font-medium">
        Motivation <span class="text-destructive">*</span>
      </label>
      <textarea
        id="motivation"
        name="motivation"
        rows="4"
        required
        class="border-border bg-background text-foreground focus:border-ring focus:ring-ring/20 w-full rounded-xl border px-3 py-2 text-sm shadow-sm transition focus:ring-2 focus:outline-none"
      ></textarea>
      <span class="text-muted-foreground text-xs">
        Why do you want to join? (10-500 characters)
      </span>
      <div class="error text-destructive hidden text-xs" id="motivationError">
      </div>
    </div>

    <div class="space-y-3">
      <label class="text-foreground text-sm font-medium">
        Code of Conduct Agreement <span class="text-destructive">*</span>
      </label>
      <div
        class="border-border bg-secondary/40 text-foreground flex items-start gap-3 rounded-xl border px-3 py-3 text-sm"
      >
        <input
          type="checkbox"
          id="agreement"
          name="agreement"
          required
          class="border-border text-primary focus:ring-primary/30 mt-1 h-4 w-4 rounded"
        />
        <label for="agreement" class="leading-5">
          I agree to follow the organization's
          <a
            href="https://github.com/stemgharbiya/.github/blob/main/CODE_OF_CONDUCT.md"
            target="_blank"
            rel="noopener noreferrer"
            class="text-primary hover:text-primary/80 underline underline-offset-4 transition"
            >Code of Conduct</a
          >
        </label>
      </div>
      <div class="error text-destructive hidden text-xs" id="agreementError">
      </div>
    </div>
    <div
      class="cf-turnstile mt-2"
      data-sitekey={TURNSTILE_SITE_KEY}
      data-theme="auto"
      data-callback="onTurnstileSuccess"
      data-error-callback="onTurnstileError"
      data-expired-callback="onTurnstileExpired"
    >
    </div>

    <button
      type="submit"
      class="btn-primary mt-4 w-full justify-center"
      id="submitBtn"
      disabled
    >
      <span id="submitText">Submit Application</span>
    </button>
  </form>

  <Fragment slot="formFooter">
    <div
      class="border-border text-muted-foreground mt-8 border-t pt-6 text-center text-sm md:mt-6"
    >
      <p>
        <a
          href="https://github.com/stemgharbiya/site/issues/new"
          target="_blank"
          rel="noopener noreferrer"
          class="text-primary hover:text-primary/80 underline underline-offset-4 transition"
          >Have a problem?</a
        >
      </p>
      <p
        class="border-border bg-secondary/40 mt-4 rounded-xl border px-4 py-3 text-xs"
      >
        To prevent spam, you can only submit one application per minute per
        school email. If you get a "Too many requests" message, please wait a
        minute before trying again.
      </p>
    </div>
  </Fragment>

  <Fragment slot="scripts">
    <script src="../../scripts/join.ts"></script>
    <script is:inline>
      const setJoinSubmitState = (enabled) => {
        const submitBtn = document.getElementById("submitBtn");
        if (submitBtn) {
          submitBtn.disabled = !enabled;
        }
      };

      window.onTurnstileSuccess = function (token) {
        setJoinSubmitState(
          token && typeof token === "string" && token.trim().length > 0,
        );
      };

      window.onTurnstileError = function (errorCode) {
        console.error("Turnstile error:", errorCode);
        setJoinSubmitState(false);
        window.showAlert?.(
          "error",
          "Captcha Failed",
          "Verification failed. Please reload the page and try again.",
        );
      };

      window.onTurnstileExpired = function () {
        setJoinSubmitState(false);
        window.showAlert?.(
          "warning",
          "Captcha Expired",
          "Verification expired. Please reload the page and try again.",
        );
      };

      const initJoinTurnstileUi = () => setJoinSubmitState(false);
      initJoinTurnstileUi();
      document.addEventListener("astro:page-load", initJoinTurnstileUi);
    </script>
  </Fragment>
</FormLayout>
